<Layouts.app flash={@flash} current_scope={@current_scope}>
  <.header>
    Dépense {@expense.id}
    <:actions>
      <.button navigate={~p"/expenses"}>
        <.icon name="hero-arrow-left" />
      </.button>
      <.button :if={@expense.user_id == @current_scope.user.id} variant="primary" navigate={~p"/expenses/#{@expense}/edit"}>
        <.icon name="hero-pencil-square" /> Modifier la dépense
      </.button>
    </:actions>
  </.header>

  <.list>
    <:item title="Date">{@expense.date}</:item>
    <:item title="Montant">{Decimal.to_string(@expense.amount, :normal)}</:item>
    <:item title="Devise">{@expense.currency}</:item>
    <:item title="Catégorie">{@expense.category.name}</:item>
    <:item title="Visibilité">{if @expense.shared, do: "Partagé", else: "Privé"}</:item>
    <:item title="Créé par">{@expense.created_by}</:item>
  </.list>
</Layouts.app>
